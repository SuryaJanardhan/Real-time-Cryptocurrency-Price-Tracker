# ==============================================================================
# CryptoStream Quantum - Environment Configuration Template
# ==============================================================================
# Copy this file to '.env' in the root directory and update the values as needed.

# 1. Base URL for CoinGecko Public REST API (historical market charts)
# Default: Public CoinGecko demo endpoint (rate-limited, with GBM fallback support)
VITE_REST_API_URL=https://api.coingecko.com/api/v3

# 2. WebSocket Endpoint for low-latency ticker stream
# Default: Binance miniTicker array stream (provides real-time volume/prices)
VITE_WS_API_URL=wss://stream.binance.com:9443/ws/!miniTicker@arr
